mute=false

function _init()

--			for i=0x3200,0x3200+64,8 do
----				poke(i,peek(i)&0b10111111)
--				poke(i,peek(i)&0b10111111)
--			end

	music()

end

function _update()
	if btnp(❎) then
		mute=not mute
	end

		if mute then
			for i=0x3100,0x3140,4 do
				poke(i,peek(i)&0b10111111)
			end
		else
			for i=0x3100,0x3140,4 do
				poke(i,peek(i)|0b01000000)
			end
		end	
	
		
end

function _draw()
	cls()
	print(mute)
	print(stat(54))
end
