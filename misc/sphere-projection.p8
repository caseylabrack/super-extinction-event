#include ../super-extinction-event.p8:1

gx,gy=0,0

function _init()

	ovi=new_ent()
	ovi.frames={bronto_idle}
	ovi.scale=4
end

function _update()

	if btn(⬅️) then ovi.x-=1 end
	if btn(➡️) then ovi.x+=1 end
	if btn(⬆️) then ovi.y-=1 end
	if btn(⬇️) then ovi.y+=1 end

end

function sph(ps)
	local os={}
	for i=1,#ps,2 do
	
		local x,y=ps[i],ps[i+1]
		local d=disto(x,y)
		
		local dz=16--distortion deadzone
		
		if d>dz then
			local z=(d-dz)/(128-dz)
			x=x/(1+z)
			y=y/(1+z)	
		end		
	
		add(os,x) 
		add(os,y)
	end	
	return os
end

function _draw()
	cls()	
	camera(-64,-64)
--	renderpoly(ovid)
	render_ent_sph(ovi)

--	line(ovi[1],ovi[2],ovi[3],ovi[4])
--	for i=5,#ovi,2 do
--		line(ovi[i],ovi[i+1])
--	end
--	line(ovi[1],ovi[2])
	

end

function render_ent_sph(e)
	if e.enabled==false then return end	
	renderpoly(sph(pushtransforms(e)),e.c)	
end

function new_ent()
	local e={}
	e.x,e.y,e.r,e.d,e.fr,e.enabled=
	0,0,0,1,1,true
	e.dx,e.dy,e.dr=
	0,0,0
	return e
end
