pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
c=8
ao=0 --angle offset
phi=1.618
⧗=0

function _init()
	
end

function _update()

	⧗+=1
--	ao+=.001
	
	if btn(⬆️) then ⧗+=1 end
	if btn(⬇️) then ⧗-=1 end
	
	
	
	phi2=phi*cos(⧗/10000)
	
end

function _draw()
	cls(0)
	
	camera(-64,-64)
	for i=1,100 do
		local a=(i+ao)*phi2
		local r=i*.5--c*sqrt(i)
		local x=cos(a)*r
		local y=sin(a)*r
		circfill(x,y,1,6)
	end
	camera()
	print(⧗)
end
