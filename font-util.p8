--utils
function font_parser(dstr)
	local	fonts={}
	for s in all(split(dstr, "|")) do
  fonts[sub(s,1,1)]=sub(s,2)
 end
 return fonts
end

function draw_char(char, x, y, col, s)
 local d=fonts[char]
 local lx,ly,first,i=0,0,true,1
 
 while i<=#d do
  local val=sub(d,i,i)
  if val=="p" then
   first=true
   i+=1
  else
   local s_vx=sub(d,i,i)
   local s_vy=sub(d,i+1,i+1)
   local vx=tonum("0x"..s_vx) or 0
   local vy=tonum("0x"..s_vy) or 0
   
   if not first then
    line(x+lx*s, y-ly*s, x+vx*s, y-vy*s, col)
   end   
   lx,ly,first,i=vx,vy,false,i+2
  end
 end
end

function cvprint(str,x,y,col,s)
	s=s or .5
	local w=0 -- width of string
	for i=1,#str do
		if str[i]==" " then 
			w+=6*s+1
		else 
		 w+=10*s+1
		end
	end
	
	vprint(str,x-w/2,y,col,s)
end

function vprint(str,x,y,col,s)
 s=s or .5
 local cx=x
 for i=1,#str do
  local c=sub(str,i,i)
  -- handle space width manually
  if c==" " then
   cx+=6*s+1
  else
   draw_char(c,cx,y,col,s)
   cx+=10*s+1
  end
 end
end
