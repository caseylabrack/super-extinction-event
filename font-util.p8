function serialize_font(tbl)
	local str=""

	for k,v in pairs(fonts_original) do
		str=str..k
		for _,point in ipairs(v) do
			if point==font_up then
				str=str.."p" 
			else
				str=str..sub(tostr(point[1],1),6,6)
				str=str..sub(tostr(point[2],1),6,6)
			end			
		end
		str=str.."|"
	end
	
	return str
end
