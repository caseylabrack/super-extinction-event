function font_parser(dstr)
	local	fonts={}
	for s in all(split(dstr, "|")) do
  fonts[sub(s,1,1)]=sub(s,2)
 end
 return fonts
end

function draw_char(char, x, y, col, s)
 local d=fonts[char]
 local lx,ly,first,i=0,0,true,1
 
 while i<=#d do
  local val=sub(d,i,i)
  local val2=sub(d,i+1,i+1)
  if val=="p" then
   first=true
   i+=1
  else
   local vx=tonum("0x"..val)
   local vy=tonum("0x"..val2)
   
   if not first then
    line(x+lx*s, y-ly*s, x+vx*s, y-vy*s, col)
   end   
   lx,ly,first,i=vx,vy,false,i+2
  end
 end
end

function cvprint(str,x,y,col,big)
	local w=0 -- width of string
	for i=1,#str do
		if str[i]==" " then 
			w+=big and 7 or 4
		else 
		 w+=big and 13 or 6
		end
	end
	
	vprint(str,x-w/2,y,col,big)
end

function vprint(str,x,y,col,big)
 local cx=x
 for i=1,#str do
  local c=sub(str,i,i)
  if c==" " then
   cx+=big and 7 or 4
  else
   draw_char(c,cx,y,col,big and 1 or .5)
			cx+=big and 13 or 6
  end
 end
end
