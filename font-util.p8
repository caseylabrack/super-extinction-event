--width of space character
--wordspacing={[.5]=2,[1]=4,[2]=7}
wordspacing={[1]=2,[2]=4,[3]=7}
--width of char plus padding
--chartracking={[.5]=4,[1]=6,[2]=13}
chartracking={[1]=4,[2]=6,[3]=13}
charwidth={[1]=.25,[2]=.5,[3]=1}
charendpad={[1]=2,[2]=2,[3]=6}


function font_parser(dstr)
	local	fonts={}
	for s in all(split(dstr, "|")) do
  fonts[sub(s,1,1)]=sub(s,2)
 end
 return fonts
end

function texttick(texts)
	for text in all(texts) do
		color(text.clr or 14)
		for i,seg in ipairs(text) do
				line()
				for pair in all(seg) do
					if pair.⧗<1 then
						pair.⧗+=.05
					else
						line(pair.x,pair.y)
					end				
				end	
		end	
	end
end

--centered vector string table
function cvstring(str,xoff,yoff,col,scale)
	scale=scale or 2
	local width=0
	for i=1,#str do
		if str[i]==" " then
--			width+=(scale==2 and 7 or 4)
			width+=wordspacing[scale]
		else
--			width+=(scale==2 and 13 or 6)
			width+=chartracking[scale]
		end
	end
--	width-=(scale==2 and 6 or 2)
	width-=charendpad[scale]
	xoff=xoff-width/2
	
	return vstring(str,xoff,yoff,col,scale)
end

--vector string table
function vstring(str,xoff,yoff,col,scale)
	
	scale=scale or 2
	local segs={} --all segments
	segs.clr=col

	local phi=0 --low dispersion randomness on vertex ⧗
	
	for i=1,#str do
		local letter=fonts[str[i]]
		local seg={}
		local j=1		

		while j<=#letter do
			local h=sub(letter,j,j)
			local h2=sub(letter,j+1,j+1)
			if h=="p" then
				add(segs,seg)
				seg={}
				j+=1
			else 
				phi+=.61803398875
				add(seg,{
--					x=tonum("0x"..h)*scale/2+xoff,
					x=tonum("0x"..h)*charwidth[scale]+xoff,
--					y=12-tonum("0x"..h2)*scale/2+yoff,
					y=12-tonum("0x"..h2)*charwidth[scale]+yoff,
					z=0,
					⧗=phi%1
				})
				j+=2
			end			
		end
		add(segs,seg)

		if str[i]==" " then
			xoff=xoff+wordspacing[scale]
		else
			xoff=xoff+chartracking[scale]
		end		
	end
	
	return segs
end
