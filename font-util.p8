function _update()
	⧗+=1
	if btnp(❎) then
		printh(serialize_font(fonts_original))
	end
	t+=.5
	
	if ⧗==5 then
--		add(txt,cvstring("extinction",64,-6,8,3))
		add(txt,cvstring("dropped super",64,8,8,1))
--		add(txt,cvstring("not just any crushed",64,20,8,1))
	end
	
	if ⧗==15 then
--		add(txt,cvstring("super of carbon",64,18,8,2))
		add(txt,cvstring("megalodon",64,18,8,2))
		add(txt,cvstring("super",64,32,8,3))
		add(txt,cvstring("extinction",64,52,8,3))
		add(txt,cvstring("event",64,72,8,3))
	end
	
	if ⧗==45 then
		add(txt,cvstring("a diamond",64,110,8,3))
--		add(txt,cvstring("press ❎ to begin",64,110,8,1))
	end
	
end

